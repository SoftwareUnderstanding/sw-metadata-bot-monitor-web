{"somef_provenance": {"somef_version": "0.10.3", "somef_schema_version": "1.0.0", "date": "2026-05-22 08:02:14"}, "code_repository": [{"result": {"value": "https://github.com/SoftwareUnderstanding/Metadata-Adoption-Quantify", "type": "Url"}, "confidence": 1, "technique": "GitHub_API"}, {"result": {"value": "https://github.com/Anas-Elhounsri/Metadata-Adoption-Quantify.git", "type": "Url"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/Metadata-Adoption-Quantify/main/codemeta.json"}], "owner": [{"result": {"value": "SoftwareUnderstanding", "type": "Organization"}, "confidence": 1, "technique": "GitHub_API"}], "date_created": [{"result": {"value": "2024-10-24T23:51:38Z", "type": "Date"}, "confidence": 1, "technique": "GitHub_API"}], "date_updated": [{"result": {"value": "2026-05-14T08:15:20Z", "type": "Date"}, "confidence": 1, "technique": "GitHub_API"}], "license": [{"result": {"value": "Apache-2.0", "type": "License", "name": "Apache License 2.0", "url": "https://spdx.org/licenses/Apache-2.0", "spdx_id": "Apache-2.0", "identifier": "https://spdx.org/licenses/Apache-2.0"}, "confidence": 1, "technique": ["GitHub_API", "file_exploration", "code_parser"], "source": ["https://raw.githubusercontent.com/SoftwareUnderstanding/Metadata-Adoption-Quantify/main/codemeta.json", "https://raw.githubusercontent.com/SoftwareUnderstanding/Metadata-Adoption-Quantify/main/LICENSE"]}, {"result": {"value": "CC0-1.0", "type": "File_dump", "name": "Creative Commons Zero v1.0", "spdx_id": "CC0-1.0", "url": "https://spdx.org/licenses/CC0-1.0"}, "confidence": 1, "technique": "file_exploration", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/Metadata-Adoption-Quantify/main/CITATION.cff"}], "description": [{"result": {"value": "This is a repository of Python scripts for processing SOMEF output that were used to extract the necessary information to answer research questions regarding the adoption of FAIR principles for research software in scientific European clusters ", "type": "String"}, "confidence": 1, "technique": ["GitHub_API", "code_parser"], "source": ["https://raw.githubusercontent.com/SoftwareUnderstanding/Metadata-Adoption-Quantify/main/codemeta.json"]}, {"result": {"type": "Text_excerpt", "value": "This software extracts relevant data from SOMEF (Software Metadata Extraction Framework) results to answer specific research questions. The extracted insights are returned as structured JSON files, allowing easy integration and analysis.\n \n", "original_header": "Metadata-Adoption-Quantify"}, "confidence": 0.8587161382766665, "technique": "supervised_classification", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/Metadata-Adoption-Quantify/main/README.md"}, {"result": {"type": "Text_excerpt", "value": "This tool is designed to process metadata extracted using SOMEF, focusing on answering predefined research questions. It parses the data from SOMEF's output and generates JSON files with the information relevant to each research question (RQ) and generating calculations for each data requested.\n \n", "original_header": "About the Software"}, "confidence": 0.991624742864867, "technique": "supervised_classification", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/Metadata-Adoption-Quantify/main/README.md"}, {"result": {"type": "Text_excerpt", "value": "1. RQ1: How do communities describe Research Software metadata in their code repositories?\n2. RQ2: What is the adoption of archival infrastructures across the disciplines?\n3. RQ3: How do software projects adopt versioning?\n4. RQ4: How comprehensive is the metadata provided in code repositories?\n5. RQ5: What are the most common citation practices among the communities?\n \n", "original_header": "Research Questions"}, "confidence": 0.9681608890488514, "technique": "supervised_classification", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/Metadata-Adoption-Quantify/main/README.md"}, {"result": {"type": "Text_excerpt", "value": "- Extract metadata from repositories using SOMEF.\n- Extracts and processes metadata from SOMEF results.\n- Filters information relevant to specific research questions.\n- Outputs the results as structured JSON files for easy review and further analysis.\n- **Custom Loading Animation**: Visual feedback during processing.\n \n", "original_header": "Features"}, "confidence": 0.9258292755351575, "technique": "supervised_classification", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/Metadata-Adoption-Quantify/main/README.md"}], "name": [{"result": {"value": "Metadata-Adoption-Quantify", "type": "String"}, "confidence": 1, "technique": "GitHub_API"}, {"result": {"value": "Metadata Adoption Quantify", "type": "String"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/Metadata-Adoption-Quantify/main/codemeta.json"}], "full_name": [{"result": {"value": "SoftwareUnderstanding/Metadata-Adoption-Quantify", "type": "String"}, "confidence": 1, "technique": "GitHub_API"}], "issue_tracker": [{"result": {"value": "https://api.github.com/repos/SoftwareUnderstanding/Metadata-Adoption-Quantify/issues", "type": "Url"}, "confidence": 1, "technique": "GitHub_API"}], "forks_url": [{"result": {"value": "https://api.github.com/repos/SoftwareUnderstanding/Metadata-Adoption-Quantify/forks", "type": "Url"}, "confidence": 1, "technique": "GitHub_API"}], "forks_count": [{"result": {"value": 1, "type": "Number"}, "confidence": 1, "technique": "GitHub_API"}], "download_url": [{"result": {"value": "https://github.com/SoftwareUnderstanding/Metadata-Adoption-Quantify/releases", "type": "Url"}, "confidence": 1, "technique": "GitHub_API"}], "programming_languages": [{"result": {"value": "Python", "name": "Python", "type": "Programming_language", "size": 103199}, "confidence": 1, "technique": "GitHub_API"}, {"result": {"name": "Python3", "value": "Pyt