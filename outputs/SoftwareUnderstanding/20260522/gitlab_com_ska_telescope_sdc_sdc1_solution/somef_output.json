-telescope/sdc1-solution/-/blob/master/etc/run_unittests.sh", "type": "Url"}, "confidence": 1, "technique": "file_exploration"}, {"result": {"value": "https://gitlab.com/ska-telescope/sdc1-solution/-/blob/master/scripts/download_data.sh", "type": "Url"}, "confidence": 1, "technique": "file_exploration"}, {"result": {"value": "https://gitlab.com/ska-telescope/sdc1-solution/-/blob/master/binder/download_sample_data.sh", "type": "Url"}, "confidence": 1, "technique": "file_exploration"}], "has_build_file": [{"result": {"value": "https://gitlab.com/ska-telescope/sdc1-solution/-/blob/master/binder/requirements.txt", "type": "Url", "format": "requirements.txt"}, "confidence": 1, "technique": "file_exploration", "source": "https://gitlab.com/ska-telescope/sdc1-solution/-/blob/master/binder/requirements.txt"}, {"result": {"value": "https://gitlab.com/ska-telescope/sdc1-solution/-/blob/master/ska/sdc1/Dockerfile", "type": "Url", "format": "dockerfile"}, "confidence": 1, "technique": "file_exploration", "source": "https://gitlab.com/ska-telescope/sdc1-solution/-/blob/master/ska/sdc1/Dockerfile"}, {"result": {"value": "https://gitlab.com/ska-telescope/sdc1-solution/-/blob/master/ska/notebook/Dockerfile", "type": "Url", "format": "dockerfile"}, "confidence": 1, "technique": "file_exploration", "source": "https://gitlab.com/ska-telescope/sdc1-solution/-/blob/master/ska/notebook/Dockerfile"}], "installation": [{"result": {"value": "To install Docker, follow the general installation instructions on the [Docker](https://docs.docker.com/install/) site:\n\n- [macOS](https://docs.docker.com/docker-for-mac/install/)\n- [Ubuntu](https://docs.docker.com/install/linux/docker-ce/ubuntu/)\n- [Windows](https://docs.docker.com/docker-for-windows/install/)\n", "type": "Text_excerpt", "original_header": "Environment setup via Docker", "parent_header": ["Science Data Challenge 1 Solution Workflow"]}, "confidence": 1, "technique": "header_analysis", "source": "https://gitlab.com/ska-telescope/sdc/sdc1-solution/-/blob/master/README.md"}], "run": [{"result": {"value": "A script for running a simple analysis workflow is provided in `scripts/sdc1_solution.py`. This assumes the data has been downloaded as described above, and mounted in the development container (performed by default by the `sdc1-start-dev` alias).\n\nThe analysis pipeline can then be run by the container's Python 3.6 interpreter:\n\n```bash\n$ PYTHONPATH=./ python3.6 scripts/sdc1_solution.py\n```\n", "type": "Text_excerpt", "original_header": "Run an analysis pipeline", "parent_header": ["Science Data Challenge 1 Solution Workflow", "Development and execution environment"]}, "confidence": 1, "technique": "header_analysis", "source": "https://gitlab.com/ska-telescope/sdc/sdc1-solution/-/blob/master/README.md"}, {"result": {"value": "```bash\n$ sdc1-run-unittests\n```\n", "type": "Text_excerpt", "original_header": "Run unit tests", "parent_header": ["Science Data Challenge 1 Solution Workflow", "Unit testing"]}, "confidence": 1, "technique": "header_analysis", "source": "https://gitlab.com/ska-telescope/sdc/sdc1-solution/-/blob/master/README.md"}, {"result": {"value": "It is possible to build an interactive environment capable of running parts of the solution workflow (compute resources dependent) using the cloud service BinderHub. To view this on the public BinderHub deployment [mybinder](https://mybinder.org/), navigate to https://mybinder.org/v2/gh/JColl88/sdc1-solution-binder/HEAD.\n", "type": "Text_excerpt", "original_header": "Run with BinderHub", "parent_header": ["Science Data Challenge 1 Solution Workflow"]}, "confidence": 1, "technique": "header_analysis", "source": "https://gitlab.com/ska-telescope/sdc/sdc1-solution/-/blob/master/README.md"}], "usage": [{"result": {"value": "After launching a BinderHub environment, some example data must be downloaded. The script `scripts/download_data.sh` is designed to download all of the requisite SDC1 data, however it is likely a BinderHub environment (such as mybinder) will not have the resources necessary to process or even store the full images.\n\nFor this situation, a small subsample of each image can be downloaded using the script `binder/download_sample_data.sh`.\n\nAfter downloading the sample data an example workflow notebook is provided at `analyse_sample.ipynb`.", "type": "Text_excerpt", "original_header": "Getting started on BinderHub", "parent_header": ["Science Data Challenge 1 Solution Workflow", "Run with BinderHub"]}, "confidence": 1, "technique": "header_analysis", "source": "https://gitlab.com/ska-telescope/sdc/sdc1-solution/-/blob/master/README.md"}], "identifier": [{"result": {"type": "Url", "value": "https://doi.org/10.5281/zenodo.5526844"}, "confidence": 1, "technique": "regular_expression", "source": "https://gitlab.com/ska-telescope/sdc/sdc1-solution/-/blob/master/README.md"}], "full_title": [{"result": {"type": "String", "value": "Science Data Challenge 1 Solution Workflow"}, "confidence": 1, "technique": "regular_expression", "source": "https://gitlab.com/ska-telescope/sdc/sdc1-solution/-/blob/master/README.md"}]}