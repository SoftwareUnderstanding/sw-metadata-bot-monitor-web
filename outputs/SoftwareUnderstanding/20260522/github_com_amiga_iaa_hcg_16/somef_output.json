{"somef_provenance": {"somef_version": "0.10.3", "somef_schema_version": "1.0.0", "date": "2026-05-22 08:03:20"}, "code_repository": [{"result": {"value": "https://github.com/AMIGA-IAA/hcg-16", "type": "Url"}, "confidence": 1, "technique": "GitHub_API"}, {"result": {"value": "git+https://github.com/AMIGA-IAA/hcg-16.git", "type": "Url"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/AMIGA-IAA/hcg-16/master/codemeta.json"}], "owner": [{"result": {"value": "AMIGA-IAA", "type": "Organization"}, "confidence": 1, "technique": "GitHub_API"}], "date_created": [{"result": {"value": "2019-02-19T12:05:11Z", "type": "Date"}, "confidence": 1, "technique": "GitHub_API"}, {"result": {"value": "2019-10-09", "type": "String"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/AMIGA-IAA/hcg-16/master/codemeta.json"}], "date_updated": [{"result": {"value": "2023-06-14T17:26:23Z", "type": "Date"}, "confidence": 1, "technique": "GitHub_API"}, {"result": {"value": "2021-09-28", "type": "String"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/AMIGA-IAA/hcg-16/master/codemeta.json"}], "license": [{"result": {"value": "MIT", "type": "License", "name": "MIT License", "url": "https://spdx.org/licenses/MIT", "spdx_id": "MIT", "identifier": "https://spdx.org/licenses/MIT"}, "confidence": 1, "technique": ["GitHub_API", "file_exploration", "code_parser"], "source": ["https://raw.githubusercontent.com/AMIGA-IAA/hcg-16/master/LICENSE", "https://raw.githubusercontent.com/AMIGA-IAA/hcg-16/master/codemeta.json"]}], "description": [{"result": {"value": "HCG-16 Project", "type": "String"}, "confidence": 1, "technique": "GitHub_API"}, {"result": {"value": "This repository hosts a pipeline to reproduce the data reduction and analysis of Jones et al. 2019.", "type": "String"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/AMIGA-IAA/hcg-16/master/codemeta.json"}, {"result": {"type": "Text_excerpt", "value": "If you have already downloaded everything and just want to re-run the pipeline then you can do so with the following command\n(Note: the hcg-16 conda environment created above must be active):\n```\npython pipeline.py make plotting --local --timeit=pipeline.time\n```\nAt present it is advised that you move or delete any output files before re-running the pipeline, as some of these files\nwon't be overwritten by default and may cause the pipeline to crash or not generate the desired output.\n \n", "original_header": "1) Pipeline for HCG-16 Project"}, "confidence": 0.9900934287505603, "technique": "supervised_classification", "source": "https://raw.githubusercontent.com/AMIGA-IAA/hcg-16/master/README.md"}, {"result": {"type": "Text_excerpt", "value": "If you do not wish to run the whole pipeline on your local machine (almost) all the figures of this project can be regenerated\nand modified using [mybinder](https://mybinder.org/) or [EGI Replay](https://replay.notebooks.egi.eu/). There is a Jupyter\nnotebook for each figure which can be run using a link to \n[mybinder](https://mybinder.org/v2/gh/AMIGA-IAA/hcg-16/HEAD) or\n[EGI Replay](https://replay.notebooks.egi.eu/v2/gh/AMIGA-IAA/hcg-16/HEAD).\nThis service can take some time to start so please be patient. \n", "original_header": "2) Plots for HCG-16 Project on the cloud"}, "confidence": 0.9955346511578658, "technique": "supervised_classification", "source": "https://raw.githubusercontent.com/AMIGA-IAA/hcg-16/master/README.md"}, {"result": {"type": "Text_excerpt", "value": "If you are only interested in downloading the final reduced data cubes these are stored on the [EUDAT B2SHARE](https://b2share.eudat.eu/records/a69a7b2dcc22449e8734552dde4d3906) service (DOI: 10.23728/b2share.a69a7b2dcc22449e8734552dde4d3906). The single cube on which most of the analysis depends is also available from [CDS](http://vizier.u-strasbg.fr/viz-bin/getCatFile?-plus=-%2b&J/A%2bA/632/A78/./fits/HCG16_CD_rob2_MS.pbcor.fits).There is also a 3D visualisation of the HI data cube hosted on the [AMIGA webpage](http://amiga-db.iaa.es/FCKeditor/UserFiles/X3D/HCG16/HCG16.html). \n", "original_header": "4) Final data and visualisation"}, "confidence": 0.9553935540438723, "technique": "supervised_classification", "source": "https://raw.githubusercontent.com/AMIGA-IAA/hcg-16/master/README.md"}], "name": [{"result": {"value": "hcg-16", "type": "String"}, "confidence": 1, "technique": "GitHub_API"}, {"result": {"value": "Pipeline for HCG-16 Project", "type": "String"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/AMIGA-IAA/hcg-16/master/codemeta.json"}], "full_name": [{"result": {"value": "AMIGA-IAA/hcg-16", "type": "String"}, "confidence": 1, "technique": "GitHub_API"}], "issue_tracker": [{"result": {"value": "https://api.github.com/repos/AMIGA-IAA/hcg-16/issues", "type": "Url"}, "confidence": 1, "technique": "GitHub_API"}, {"result": {"value": "https://github.com/AMIGA-IAA/hcg-16/issues", "type": "Url"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/AMIGA-IAA/hcg-16/master/codemeta.json"}], "forks_url": [{"result": {"value": "https://api.github.com/repos/AMIGA-IAA/hcg-16/forks", "type": "Url"}, "confidence": 1, "technique": "GitHub_API"}], "stargazers_count": [{"result": {"value": 2, "type": "Number"}, "confidence": 1, "technique": "GitHub_API"}], "download_url": [{"result": {"value": "https://github.com/AMIGA-IAA/hcg-16/releases", "type": "Url"}, "confidence": 1, "technique": "GitHub_API"}, {"result": {"value": "https://github.com/AMIGA-IAA/hcg-16/releases/tag/v1.2.1", "type": "Url"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/AMIGA-IAA/hcg-16/master/codemeta.json"}], "programming_languages": [{"result": {"value": "Python", "name": "Python", "type": "Programming_language", "size": 118019}, "confidence": 1,