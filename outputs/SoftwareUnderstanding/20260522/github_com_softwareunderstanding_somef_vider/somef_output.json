template-compiler", "version": "^2.6.11", "type": "SoftwareDependency", "dependency_type": "development", "dependency_resolver": "npm"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/client/package.json"}, {"result": {"value": "vuetify-loader@^1.7.0", "name": "vuetify-loader", "version": "^1.7.0", "type": "SoftwareDependency", "dependency_type": "development", "dependency_resolver": "npm"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/client/package.json"}, {"result": {"value": "* npm 6.14.8\n* Python 3.9\n", "type": "Text_excerpt", "original_header": "Dependencies", "parent_header": ["SOMEF Vider", "Development Installation"]}, "confidence": 1, "technique": "header_analysis", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/README.md"}], "has_script_file": [{"result": {"value": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/server/installer.sh", "type": "Url"}, "confidence": 1, "technique": "file_exploration"}], "runtime_platform": [{"result": {"value": "Python: 2.8.2", "version": "2.8.2", "name": "Python", "type": "String", "dependency_type": "runtime", "dependency_resolver": "pip"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/server/requirements.txt"}], "package_id": [{"result": {"value": "client", "type": "String"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/client/package.json"}], "has_package_file": [{"result": {"value": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/client/package.json", "type": "Url"}, "confidence": 1, "technique": "code_parser", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/client/package.json"}], "usage": [{"result": {"value": "We have a running demo in [https://somef.linkeddata.es](https://somef.linkeddata.es). If the demo is down, please let us know by opening an issue.\n", "type": "Text_excerpt", "original_header": "Demo", "parent_header": ["SOMEF Vider"]}, "confidence": 1, "technique": "header_analysis", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/README.md"}], "installation": [{"result": {"value": "In the development installation client and service are independent. They are mounted and executed separately\nfrom each other.\n", "type": "Text_excerpt", "original_header": "Development Installation", "parent_header": ["SOMEF Vider"]}, "confidence": 1, "technique": "header_analysis", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/README.md"}, {"result": {"value": "Clone this repository\n```\n$ git clone https://github.com/SoftwareUnderstanding/SOMEF-Vider.git      \n```\n", "type": "Text_excerpt", "original_header": "Installation", "parent_header": ["SOMEF Vider", "Development Installation"]}, "confidence": 1, "technique": "header_analysis", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/README.md"}, {"result": {"value": "Before installation, configure the target server in `client/src/service/axiosService` by changing the variable `LOCAL_URL`. For local tests, use `127.0.0.1:5000` (assuming the application is deployed in that port).\n\nInstall dependencies for client\n```\n$ cd SOMEF-Vider/client/\n```\n```\n$ npm install\n```\nRun client\n```\n$ npm run serve\n```\n", "type": "Text_excerpt", "original_header": "Client", "parent_header": ["SOMEF Vider", "Development Installation", "Installation"]}, "confidence": 1, "technique": "header_analysis", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/README.md"}, {"result": {"value": "Install dependencies for server\n```\ncd SOMEF-Vider/server/\n```\n```\npython3.9 -m venv virtualenv/\n```\n```\nsource virtualenv/bin/activate \n```\n```\npython -m pip install -r requirements.txt --no-dependencies\n```\n```\npython -m nltk.downloader all\n```\nRun service. Run on default host 0.0.0.0 and port 5000. Debuf is recommended to be false on production.\n``` \npython app.py\n```\n\nBut now we can specify a custom port,\n``` \npython app.py --port 23705\n```\n\na custom host and port,\n``` \npython app.py --host 127.0.0.1 --port 8000\n```\n\nor enable debug mode in development proccess\n``` \npython app.py --debug\n```\n\nor combine custom host, port and debug\n``` \npython app.py --host 0.0.0.0 --port 23705 --debug\n```\n", "type": "Text_excerpt", "original_header": "Service", "parent_header": ["SOMEF Vider", "Development Installation", "Installation"]}, "confidence": 1, "technique": "header_analysis", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/README.md"}, {"result": {"value": "It follows roughly the same process as the development installation but, in this case, the client is compiled and\nintegrated into the flask service.\n\nGo to the client folder and install the dependencies if they are not installed.\n\n```\n$ cd SOMEF-Vider/client/\n$ npm install\n```\nNow instead of running the client, execute the following command to build it:\n```\n$ npm run build\n```\nThis will generate a new folder in the current directory called \"dist\" with all the client files compiled.\nTo integrate this files in the service, just move the folder \"dist\" to the service folder and rename it to \"static\".\n```\n$ mv dist ../server/static\n```\nThis last 2 mandates are (for now) the only difference between development and production. To run the tool\nfollow the steps listed above at the \"Service\" section.\n\nTo generate the bundle with Docker, see the [client deployment instructions](https://github.com/SoftwareUnderstanding/SOMEF-Vider/blob/master/client/README.md).\n", "type": "Text_excerpt", "original_header": "Production installation", "parent_header": ["SOMEF Vider"]}, "confidence": 1, "technique": "header_analysis", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/README.md"}], "contributing_guidelines": [{"result": {"value": "If you find problems or if you wish to add new features, please let us know by opening an [issue](https://github.com/SoftwareUnderstanding/SOMEF-Vider/issues) or submitting a pull request.", "type": "Text_excerpt", "original_header": "Contributing", "parent_header": ["SOMEF Vider"]}, "confidence": 1, "technique": "header_analysis", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/README.md"}], "application_domain": [{"result": {"type": "String", "value": "Semantic web"}, "confidence": 0.805776869910609, "technique": "supervised_classification"}], "full_title": [{"result": {"type": "String", "value": "SOMEF Vider"}, "confidence": 1, "technique": "regular_expression", "source": "https://raw.githubusercontent.com/SoftwareUnderstanding/SOMEF-Vider/master/README.md"}]}